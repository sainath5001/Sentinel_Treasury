# Sepolia environment variables — copy to .env and fill in values.
# NEVER commit .env to version control.

# Deployer wallet private key (without 0x prefix)
PRIVATE_KEY=

# Optional: separate admin address for roles (defaults to deployer)
ADMIN_ADDRESS=

# Optional: initial STT supply in wei (defaults to 1_000_000 ether)
INITIAL_SUPPLY=

# Alchemy Sepolia RPC (https://dashboard.alchemy.com → Create App → Ethereum Sepolia)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=
